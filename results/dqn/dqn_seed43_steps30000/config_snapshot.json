{
  "project": {
    "name": "budgeted_interactive_movie_recommender_rl"
  },
  "seed": 42,
  "environment": {
    "max_steps": 12,
    "question_budget": 3,
    "question_budget_mode": "hard",
    "initial_uncertainty": 0.7,
    "initial_engagement": 0.8
  },
  "reward": {
    "acceptance_reward": 6.0,
    "engagement_bonus_scale": 0.9,
    "skip_penalty": -1.0,
    "question_cost": -0.08,
    "question_information_gain_scale": 4.8,
    "over_budget_penalty": -1.0,
    "abandonment_penalty": -4.5,
    "repetition_penalty": -0.25
  },
  "q_learning": {
    "episodes": 3000,
    "learning_rate": 0.2,
    "discount_factor": 0.95,
    "epsilon_start": 1.0,
    "epsilon_min": 0.05,
    "epsilon_decay": 0.995,
    "discretization_bins": {
      "belief_margin": 4,
      "uncertainty": 5,
      "engagement": 5,
      "budget": 4,
      "step": 6,
      "asked": 4,
      "recommended": 4,
      "repeats": 4
    },
    "eval_episodes": 120
  },
  "dqn": {
    "total_timesteps": 30000,
    "learning_rate": 0.0005,
    "batch_size": 64,
    "buffer_size": 12000,
    "learning_starts": 500,
    "gamma": 0.97,
    "target_update_interval": 250,
    "train_freq": 4,
    "eval_episodes": 120
  },
  "ppo": {
    "total_timesteps": 30000,
    "learning_rate": 0.0003,
    "n_steps": 128,
    "batch_size": 64,
    "gamma": 0.97,
    "gae_lambda": 0.95,
    "ent_coef": 0.01,
    "eval_episodes": 120
  },
  "evaluation": {
    "episodes": 150
  }
}